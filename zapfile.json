ride": 0, "block_and_release_limit_override": 0, "spread_tasks": 1}, "folders": null, "parent_id": 367230615, "root_id": 367229956, "action": "filter", "selected_api": "BranchingAPI", "title": "Path B", "authentication_id": null, "created_at": "2026-06-04T11:16:12+00:00", "last_changed": "2026-06-11T04:56:52+00:00"}, "367230621": {"id": 367230621, "account_id": 27689831, "customuser_id": 27835357, "paused": true, "type_of": "write", "params": {"table_id": "01KT95WE3FH7RZYVJX52J36NQ6"}, "meta": {"$editor": {"has_automatic_issues": false}, "parammap": {"table_id": "[Table] Retell AI call qualification & Airtable lead update Table"}}, "triple_stores": {"copied_from": null, "created_by": null, "polling_interval_override": 0, "block_and_release_limit_override": 0, "spread_tasks": 1}, "folders": null, "parent_id": 367230620, "root_id": 367229956, "action": "create_record", "selected_api": "TableCLIAPI@1.21.0", "title": null, "authentication_id": null, "created_at": "2026-06-04T11:16:12+00:00", "last_changed": "2026-06-11T04:56:52+00:00"}, "367230619": {"id": 367230619, "account_id": 27689831, "customuser_id": 27835357, "paused": true, "type_of": "write", "params": {"provider_id": "google", "authentication_id": "0", "model_id": "google/gemini-2.0-flash", "isOutputArray": false, "instructions": "Analyze the following call transcript to qualify a lead based on three criteria:\n1. Caller is in Texas (state = TX)\n2. Caller is a homeowner (homeowner = true)\n3. Caller has at least $10,000 available immediately\n\nBased on the transcript, extract:\n- state: Extract caller's state (return 'TX' if Texas, 'other' if different state, 'unknown' if not mentioned)\n- homeowner: Extract homeowner status (return true if confirmed homeowner, false if renter/other, 'unknown' if not mentioned)\n- cash_available_now: Extract numeric value of available cash/funds mentioned (return 0 if none mentioned or unknown)\n- qualified: Return true only if ALL three are met: state=='TX' AND homeowner==true AND cash_available_now >= 10000. Otherwise return false.\n- reason: Provide a short explanation (max 100 chars) of the qualification decision\n\nTranscript:\n{{367229956__transcript}}", "inputFields": {"transcript": "{{367229956__transcript}}"}, "outputSchema": {"state": "State extracted from call (TX, other, or unknown)", "homeowner": "Homeowner status (true, false, or unknown)", "cash_available_now": "Numeric amount of available cash", "qualified": "Boolean - true if all 3 criteria met", "reason": "Short explanation of qualification status"}}, "meta": {"$editor": {"has_automatic_issues": false}, "parammap": {"provider_id": "Google", "authentication_id": "0", "model_id": "Gemini 2.0 Flash"}}, "triple_stores": {"copied_from": null, "created_by": null, "polling_interval_override": 0, "block_and_release_limit_override": 0, "spread_tasks": 1}, "folders": null, "parent_id": 367230618, "root_id": 367229956, "action": "get_completion", "selected_api": "AICLIAPI@3.8.5", "title": null, "authentication_id": null, "created_at": "2026-06-04T11:16:12+00:00", "last_changed": "2026-06-11T04:56:52+00:00"}, "367230706": {"id": 367230706, "account_id": 27689831, "customuser_id": 27835357, "paused": true, "type_of": "write", "params": {"applicationId": "appkFRzu6N4w38vYx", "tableName": "tblEq67s4OxfG3bq9", "rowId": "{{367229980__id}}", "fields__fldiR8xGXqQxConUm": "Qualified: {{367230619__qualified}} | State: {{367230619__state}} | Homeowner: {{367230619__homeowner}} | Cash: {{367230619__cash_available_now}} | Reason: {{367230619__reason}}"}, "meta": {"$editor": {"has_automatic_issues": false}, "parammap": {"applicationId": "Untitled Base", "tableName": "Table 1"}}, "triple_stores": {"copied_from": null, "created_by": null, "polling_interval_override": 0, "block_and_release_limit_override": 0, "spread_tasks": 1}, "folders": null, "parent_id": 367230619, "root_id": 367229956, "action": "updateRecord", "selected_api": "AirtableCLIAPI@3.13.0", "title": null, "authentication_id": 64