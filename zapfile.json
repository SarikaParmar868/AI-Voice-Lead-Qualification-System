{"metadata": {"version": "gdpr_v1"}, "zaps": [{"id": 367229956, "title": "Retell AI call qualification & Airtable lead update", "status": "off", "nodes": {"367229956": {"id": 367229956, "account_id": 27689831, "customuser_id": 27835357, "paused": true, "type_of": "read", "params": {}, "meta": {"$editor": {"has_automatic_issues": false}, "stepTitle": "Receive Retell AI call_ended webhook"}, "triple_stores": {"copied_from": null, "created_by": null, "polling_interval_override": 0, "block_and_release_limit_override": 0, "spread_tasks": 1}, "folders": null, "parent_id": null, "root_id": null, "action": "hook_raw", "selected_api": "WebHookCLIAPI@1.1.1", "title": "Retell AI call qualification & Airtable lead update", "authentication_id": null, "created_at": "2026-06-04T11:10:06+00:00", "last_changed": "2026-06-11T05:22:25+00:00"}, "367229957": {"id": 367229957, "account_id": 27689831, "customuser_id": 27835357, "paused": true, "type_of": "write", "params": {"input": {"raw_body": "{{367229956__raw_body}}"}, "packages_enabled": false, "code": "// Parse raw webhook body\nlet data;\ntry {\n  data = typeof inputData.raw_body === 'string' ? JSON.parse(inputData.raw_body) : inputData.raw_body;\n} catch (e) {\n  return { phone: '', error: 'Invalid JSON' };\n}\n\n// Try multiple possible phone field names that Retell might use\nlet callerPhone = (\n  data.caller_phone || \n  data.from_number || \n  data.to_number || \n  data.phone || \n  data.phone_number || \n  data.callerNumber ||\n  data.callerId ||\n  data.calling_number ||\n  ''\n).toString().trim();\n\nif (!callerPhone || callerPhone === '') {\n  return { phone: '', error: 'No phone number found' };\n}\n\n// Remove formatting: spaces, dashes, parentheses\nconst cleaned = callerPhone.replace(/[\\s\\-()]/g, '');\n\n// Ensure starts with +\nconst withPlus = cleaned.startsWith('+') ? cleaned : '+' + cleaned;\n\n// Extract digits for validation\nconst digitsOnly = withPlus.replace(/\\D/g, '');\n\n// Validate E.164 format (10-15 digits)\nif (digitsOnly.length < 10 || digitsOnly.length > 15) {\n  return { phone: '', error: 'Invalid format' };\n}\n\nconst e164Phone = '+' + digitsOnly;\n\n// Also extract transcript and call_id for later steps\nreturn { \n  phone: e164Phone,\n  transcript: data.transcript || data.call_transcript || '',\n  call_id: data.call_id || data.id || '',\n  call_end_time: data.call_end_time || data.end_time || '',\n  error: null \n};"}, "meta": {"$editor": {"has_automatic_issues": false}, "parammap": {}}, "triple_stores": {"copied_from": null, "created_by": null, "polling_interval_override": 0, "block_and_release_limit_override": 0, "spread_tasks": 1}, "folders": null, "parent_id": 367229956, "root_id": 367229956, "action": "01929fad-d3dd-62c2-52ed-7868d5fcc691", "selected_api": "CodeCLIAPI@1.0.1", "title": null, "authentication_id": null, "created_at": "2026-06-04T11:10:06+00:00", "last_changed": "2026-06-11T04:56:52+00:00"}, "367229980": {"id": 367229980, "account_id": 27689831, "customuser_id": 27835357, "paused": true, "type_of": "search", "params": {"isExactMatch": "true", "_zap_search_success_on_miss": "true", "_zap_search_multiple_results": "first", "applicationId": "appkFRzu6N4w38vYx", "tableName": "tblEq67s4OxfG3bq9", "searchByField": "Phone", "searchByValue": "{{367229957__phone}}"}, "meta": {"$editor": {"has_automatic_issues": false}, "parammap": {"applicationId": "Untitled Base", "isExactMatch": "Exact Match", "_zap_search_success_on_miss": "True: step run status is success.", "_zap_search_multiple_results": "Return first search result. Step run status is success. (Default)", "tableName": "Table 1", "searchByField": "Phone"}, "stepTitle": "Find Record"}, "triple_stores": {"copied_from": null, "created_by": null, "polling_interval_override": 0, "block_and_release_limit_override": 0, "spread_tasks": 1}, "folders": null, "parent_id": 367229957, "root_id": 367229956, "action": "findRecord", "selected_api": "AirtableCLIAPI@3.13.0", "title": null, "authentication_id